# Copy to .env. Never commit the real file.

PROJECTS_DIR=./workspace
PUID=1000
PGID=1000
TZ=Europe/Warsaw

CODEFORGE_IMAGE=codeforge-agent:latest

CODEFORGE_FOREGROUND_YIELD_MS=10000
CODEFORGE_MAX_CONCURRENT_PROCESSES=8
CODEFORGE_PROCESS_TIMEOUT_SECONDS=1800
CODEFORGE_HTTP_ADDRESS=:9000
# Optional. Protects /mcp and /tools/* when set. Use bearer auth for OpenAI.
# /openapi.json stays public.
# CODEFORGE_API_KEY=change-me-to-a-real-key

CODEFORGE_STATE_VOLUME=codeforge-state
CODEFORGE_HOME_VOLUME=codeforge-home

# Optional nested Docker daemon used by compose.dind.yaml.
DOCKER_DIND_IMAGE=docker:29.5-dind
CODEFORGE_DOCKER_VOLUME=codeforge-docker-data
