# Copy to .env. Never commit the real file.

PROJECTS_DIR=./workspace
HOST_UID=1000
HOST_GID=1000
TZ=Europe/Warsaw

# OpenAI Secure MCP Tunnel.
CONTROL_PLANE_TUNNEL_ID=tunnel_0123456789abcdef0123456789abcdef
CONTROL_PLANE_API_KEY=sk-replace-me
TUNNEL_UI_PORT=8080
TUNNEL_LOG_LEVEL=info
TUNNEL_LOG_FORMAT=struct-text

# Reproducible image inputs.
GO_VERSION=1.25
ALPINE_VERSION=3.22
UV_VERSION=0.11.24
TUNNEL_CLIENT_VERSION=v0.0.9--context-conduit-topaz
CODEFORGE_IMAGE=codeforge-agent:latest

# Optional space-separated Alpine packages required by your repositories.
# Example: EXTRA_APK_PACKAGES=protobuf sqlite-dev libffi-dev
EXTRA_APK_PACKAGES=

CODEFORGE_FOREGROUND_YIELD_MS=10000
CODEFORGE_MAX_CONCURRENT_PROCESSES=8
CODEFORGE_PROCESS_TIMEOUT_SECONDS=1800

CODEFORGE_STATE_VOLUME=codeforge-state
CODEFORGE_HOME_VOLUME=codeforge-home
TUNNEL_STATE_VOLUME=codeforge-tunnel-state

# Optional nested Docker daemon used by compose.dind.yaml.
DOCKER_DIND_IMAGE=docker:29.5-dind
CODEFORGE_DOCKER_VOLUME=codeforge-docker-data
