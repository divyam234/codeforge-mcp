# Directory containing one or more projects. If this directory is itself a
# repository, CodeForge treats it as project "." for backward compatibility.
CODEFORGE_WORKSPACE_ROOT=/absolute/path/to/projects

# Optional project ID selected at startup. Use a value returned by project_list.
# CODEFORGE_ACTIVE_PROJECT=my-project

# Persistent plan/task state. Keep this outside project repositories.
# In Docker, mount a volume at /state.
CODEFORGE_STATE_DIR=/state

# HTTP endpoint exposed alongside stdio. Serves MCP at /mcp, OpenAPI at
# /openapi.json, and REST tool calls at /tools/{tool_name}.
CODEFORGE_HTTP_ADDRESS=:9000
# Optional. When set, /mcp and /tools/* require Authorization: Bearer <key>.
# X-API-Key is also accepted for non-OpenAI clients. /openapi.json stays public.
# CODEFORGE_API_KEY=change-me-to-a-real-key

CODEFORGE_COMMAND_POLICY=unrestricted
CODEFORGE_SHELL=/bin/bash

# Optional restricted mode: direct argv only.
# CODEFORGE_COMMAND_POLICY=allowlist
CODEFORGE_ALLOWED_COMMANDS=go,git,rg,gofmt,goimports,golangci-lint,staticcheck,make,just,cargo,rustc,npm,npx,pnpm,yarn,node,python,python3,pytest

CODEFORGE_ALLOW_DELETE=true
CODEFORGE_MAX_FILE_BYTES=4194304
CODEFORGE_MAX_SEARCH_RESULTS=300
CODEFORGE_MAX_TREE_ENTRIES=3000
CODEFORGE_MAX_CONCURRENT_PROCESSES=4
CODEFORGE_MAX_PROCESS_OUTPUT_BYTES=8388608
CODEFORGE_PROCESS_TIMEOUT_SECONDS=600

# command_run waits this long before automatically returning a process session.
# Maximum: 30000 ms.
CODEFORGE_FOREGROUND_YIELD_MS=10000

# Build tools and child commands inherit the normal process environment.
# Configure Go using standard Go variables when needed, for example:
# GOPROXY=https://proxy.example.com,direct
# GOPRIVATE=git.example.com/*
